# =============================================================================
# SafeSite Documents — Environment Variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# =============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the site (used for SEO canonical URLs, sitemap, emails).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Database (Prisma) -------------------------------------------------------
# Postgres connection string. Works great with Supabase, Neon, or RDS.
# Example (Supabase): postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/safesite?schema=public"
# Optional pooled connection for serverless (Supabase/Neon "pgbouncer") :
DIRECT_URL="postgresql://user:password@localhost:5432/safesite?schema=public"

# --- Auth (NextAuth.js) ------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
# OAuth providers (optional) — create credentials in the provider console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Stripe ------------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# Webhook signing secret from `stripe listen` or the Stripe dashboard.
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Stripe Price IDs (create Products/Prices in Stripe, then paste IDs here).
# Subscriptions:
NEXT_PUBLIC_STRIPE_PRICE_LIBRARY_STARTER="price_xxx"   # $49/mo
NEXT_PUBLIC_STRIPE_PRICE_LIBRARY_PRO="price_xxx"       # $99/mo
# One-time custom binder packages:
NEXT_PUBLIC_STRIPE_PRICE_CUSTOM_BINDER="price_xxx"     # $799
NEXT_PUBLIC_STRIPE_PRICE_CONTRACTOR_PRO="price_xxx"    # $1,499
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_SYSTEM="price_xxx"    # $2,499

# --- Email (transactional) ---------------------------------------------------
# Use Resend (https://resend.com) or SendGrid. Only one is required.
RESEND_API_KEY="re_xxx"
EMAIL_FROM="SafeSite Documents <noreply@safesitedocs.org>"
# Where intake-form submissions and contact messages are routed internally.
SALES_INBOX="contact@safesitedocs.org"

# --- File storage / CMS (optional) ------------------------------------------
# If documents are served from Supabase Storage / S3 / a headless CMS,
# put the bucket/base URL + service keys here.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""        # server-only, never expose to the client
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
DOCUMENT_STORAGE_BUCKET="documents"

# --- Analytics (optional) ----------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
